// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — Cloudflare D1 (SQLite)
//
// Changes from the original PostgreSQL schema:
//   1. generator provider  → "prisma-client" (new adapter-based client)
//                            + runtime = "cloudflare" for D1 support
//   2. datasource provider → "sqlite"  (no url here; supplied via prisma.config.ts)
//   3. directUrl removed   → not supported / not needed with D1
//   4. Cart.expiresAt      → dbgenerated() updated to SQLite datetime syntax
//   5. Additional indexes  → added on hot query paths per D1 best-practices
//      (Booking, Photo, CartEmail, ReferralReward already had theirs)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
    runtime  = "cloudflare"
}

datasource db {
    // D1 is SQLite under the hood.
    // The database URL is NOT set here — it is injected at runtime via the
    // PrismaD1 adapter (env.DB binding) and locally via prisma.config.ts.
    provider = "sqlite"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model Account {
    id                String  @id @default(uuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    // Index userId so cascading deletes and user-account look-ups are fast
    @@index([userId])
}

model Session {
    id           String   @id @default(uuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Fast look-up of all sessions for a user (e.g. logout-all-devices)
    @@index([userId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
    id               String    @id @default(uuid())
    name             String?
    email            String    @unique
    emailVerified    DateTime?
    password         String?
    role             String    @default("CLIENT")
    phone            String?
    image            String?
    resetToken       String?
    resetTokenExpiry DateTime?
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt

    referralCode   String? @unique
    referredById   String?
    referralPoints Int     @default(0)

    // Self-referential referral tree
    referredBy User?  @relation("Referrals", fields: [referredById], references: [id])
    referrals  User[] @relation("Referrals")

    accounts            Account[]
    sessions            Session[]
    bookings            Booking[]
    carts               Cart[]
    favorites           Favorite[]
    ratings             Rating[]
    ReferralCode        ReferralCode[]
    ReferralReward      ReferralReward[]
    PromotionSubscriber PromotionSubscriber[]
    PointsRedemption    PointsRedemption[]
    discountUsages      DiscountUsage[]

    // Filter users by role (e.g. admin dashboards listing all CLIENTs)
    @@index([role])
    // Look up users by referral chain
    @@index([referredById])
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
    id            String   @id @default(uuid())
    name          String
    price         Int
    stripePriceId String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    bookings  Booking[]
    carts     Cart[]
    favorites Favorite[]
    ratings   Rating[]
}

// ─── Bookings ────────────────────────────────────────────────────────────────

model Booking {
    id             String   @id @default(uuid())
    serviceId      String
    userId         String?
    date           DateTime
    time           String
    paymentMethod  String
    mobileProvider String?
    email          String?
    userName       String
    phone          String
    status         String   @default("PENDING")
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    service Service  @relation(fields: [serviceId], references: [id])
    user    User?    @relation(fields: [userId], references: [id])
    photos  Photo[]

    // Common query patterns:
    //   - Admin: all bookings for a service
    //   - User:  their own bookings
    //   - Admin: bookings filtered by status (PENDING / CONFIRMED / etc.)
    //   - Calendar: bookings for a specific date
    @@index([serviceId])
    @@index([userId])
    @@index([status])
    @@index([date])
    // Composite: admin dashboard "pending bookings by service" query
    @@index([serviceId, status])
}

model Photo {
    id        String   @id @default(uuid())
    bookingId String
    url       String
    createdAt DateTime @default(now())

    booking Booking @relation(fields: [bookingId], references: [id])

    @@index([bookingId])
}

// ─── Cart ────────────────────────────────────────────────────────────────────

model Cart {
    id        String   @id @default(uuid())
    userId    String?
    serviceId String
    date      DateTime
    time      String
    quantity  Int      @default(1)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // SQLite datetime default — replaces PostgreSQL's "now() + interval '24 hours'"
    expiresAt DateTime @default(dbgenerated("(datetime('now', '+24 hours'))"))

    user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([serviceId])
    // Expire-scan: find all carts past their expiry time
    @@index([expiresAt])
}

model CartEmail {
    id        String    @id @default(uuid())
    userId    String?
    email     String
    cartItems String    // JSON stored as TEXT in SQLite (was Json in PostgreSQL)
    sent      Boolean   @default(false)
    sentAt    DateTime?
    createdAt DateTime  @default(now())
    expiresAt DateTime

    // Look up unsent emails by user or email address
    @@index([userId])
    @@index([email])
    // Sweep job: find unsent emails not yet expired
    @@index([sent, expiresAt])
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
    id        String   @id @default(uuid())
    userId    String
    serviceId String
    createdAt DateTime @default(now())

    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    @@unique([userId, serviceId])
    @@index([userId])
    // Reverse look-up: how many users favorited a service
    @@index([serviceId])
}

// ─── Referrals ───────────────────────────────────────────────────────────────

model ReferralCode {
    id                String   @id @default(uuid())
    code              String   @unique
    userId            String
    pointsPerReferral Int      @default(100)
    usageCount        Int      @default(0)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model ReferralReward {
    id         String   @id @default(uuid())
    referrerId String
    referredId String
    points     Int
    bookingId  String?
    createdAt  DateTime @default(now())
    userId     String?

    User User? @relation(fields: [userId], references: [id])

    @@index([referrerId])
    @@index([referredId])
}

// ─── Promotions ──────────────────────────────────────────────────────────────

model PromotionSubscriber {
    id         String   @id @default(uuid())
    email      String   @unique
    name       String?
    phone      String?
    userId     String?
    subscribed Boolean  @default(true)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([userId])
    // Filter active subscribers for campaign sends
    @@index([subscribed])
}

// ─── Points & Discounts ──────────────────────────────────────────────────────

model PointsRedemption {
    id             String   @id @default(uuid())
    userId         String
    points         Int
    discountAmount Int
    bookingId      String?
    status         String   @default("PENDING") // PENDING | APPLIED | EXPIRED
    createdAt      DateTime @default(now())
    expiresAt      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    // Sweep job: expire PENDING redemptions past expiresAt
    @@index([status, expiresAt])
}

model DiscountCode {
    id        String   @id @default(uuid())
    code      String   @unique
    type      String   // "PERCENT" | "FIXED"
    value     Int
    minAmount Int?
    maxUses   Int?
    usedCount Int      @default(0)
    expiresAt DateTime?
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    usages DiscountUsage[]

    @@index([code])
    // Filter active codes (admin list, validation)
    @@index([active])
}

model DiscountUsage {
    id             String   @id @default(uuid())
    discountCodeId String
    userId         String?
    email          String?
    userName       String?
    phone          String?
    discountAmount Int
    cartTotal      Int
    finalTotal     Int
    bookingId      String?
    createdAt      DateTime @default(now())

    discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
    user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([discountCodeId])
    @@index([userId])
    @@index([email])
}

// ─── Ratings ─────────────────────────────────────────────────────────────────

model Rating {
    id        String   @id @default(uuid())
    userId    String
    serviceId String
    rating    Int      // 1–5
    comment   String?
    status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    @@unique([userId, serviceId])
    @@index([serviceId])
    @@index([userId])
    @@index([status])
    // Composite: approved ratings for a specific service (public display)
    @@index([serviceId, status])
}
